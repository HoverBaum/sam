{
  "tasks": {
    "dev": "deno run -A cli.tsx",
    "build": "deno compile -A --output sam cli.tsx",
    "test": "deno test -A tests",
    "check": "deno check cli.tsx"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "jsx": "react",
    "types": [
      "npm:@types/react@^18.3.12"
    ]
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1.1.2",
    "@std/fs": "jsr:@std/fs@^1.0.20",
    "@std/assert": "jsr:@std/assert@^1.0.15",
    "react": "npm:react@^18.3.1",
    "ink": "npm:ink@^5.0.1",
    "ink-gradient": "npm:ink-gradient@^3.0.0",
    "ink-scroll-view": "npm:ink-scroll-view@^0.3.6",
    "ink-select-input": "npm:ink-select-input@^6.2.0",
    "ink-spinner": "npm:ink-spinner@^5.0.0",
    "react-router": "npm:react-router@^7.5.3",
    "ai": "npm:ai@^4.3.16",
    "@ai-sdk/anthropic": "npm:@ai-sdk/anthropic@^1.2.10",
    "@ai-sdk/openai": "npm:@ai-sdk/openai@^1.3.23",
    "@ai-sdk/google": "npm:@ai-sdk/google@^1.2.18",
    "@ai-sdk/mistral": "npm:@ai-sdk/mistral@^1.2.8",
    "@ai-sdk/groq": "npm:@ai-sdk/groq@^1.2.7"
  }
}
